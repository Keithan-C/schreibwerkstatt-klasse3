<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diktat-Trainer – Klasse 3</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Nunito+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<style>
/* ─── TOKENS ─────────────────────────────────────────── */
:root {
  --bg:        #F3F6FF;
  --surface:   #FFFFFF;
  --border:    #DDE3F4;
  --border-md: #BFC8E8;

  --ink:       #1C1F3A;
  --ink2:      #3A3F6A;
  --muted:     #7880A8;

  --blue:      #3B6CF7;
  --blue-lt:   #EEF2FF;
  --blue-mid:  #93ADFC;

  --green:     #15A056;
  --green-lt:  #E6F7EE;
  --green-mid: #7DD4A8;

  --amber:     #C07A00;
  --amber-lt:  #FFF8E6;
  --amber-mid: #F5C842;

  --red:       #D43030;
  --red-lt:    #FCEAEA;
  --red-mid:   #F4A0A0;

  --purple:    #6B3FC8;
  --purple-lt: #F0EBFF;

  --r:   12px;
  --r-lg:20px;
  --r-sm: 8px;

  --shadow:    0 2px 12px rgba(28,31,58,0.07);
  --shadow-md: 0 4px 24px rgba(28,31,58,0.11);
}

/* ─── RESET ───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  color: var(--ink);
  min-height: 100vh;
  padding-bottom: 60px;
}

/* ─── HEADER ──────────────────────────────────────────── */
.site-header {
  background: var(--blue);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  box-shadow: 0 2px 10px rgba(59,108,247,0.25);
  position: sticky;
  top: 0;
  z-index: 100;
}
.header-icon { font-size: 28px; line-height: 1; flex-shrink: 0; }
.header-titles { flex: 1; }
.header-title {
  font-size: clamp(16px, 3vw, 20px);
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
}
.header-sub {
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  margin-top: 2px;
}
.header-badge {
  background: rgba(255,255,255,0.18);
  border: 1.5px solid rgba(255,255,255,0.3);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  white-space: nowrap;
}

/* ─── WRAP ────────────────────────────────────────────── */
.wrap { max-width: 700px; margin: 0 auto; padding: 24px 16px; }

/* ─── THEME SELECTOR ──────────────────────────────────── */
.section-label {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  margin-bottom: 10px;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 8px;
  margin-bottom: 24px;
}
.theme-btn {
  padding: 12px 10px;
  border: 2px solid var(--border);
  border-radius: var(--r);
  background: var(--surface);
  cursor: pointer;
  font-family: 'Nunito', sans-serif;
  text-align: center;
  transition: all 0.18s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  min-height: 72px;
  justify-content: center;
}
.theme-btn:hover {
  border-color: var(--blue-mid);
  background: var(--blue-lt);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}
.theme-btn.active {
  border-color: var(--blue);
  background: var(--blue-lt);
  box-shadow: 0 0 0 3px rgba(59,108,247,0.15);
}
.theme-btn .t-emoji { font-size: 22px; line-height: 1; }
.theme-btn .t-name {
  font-size: 13px;
  font-weight: 800;
  color: var(--ink);
  line-height: 1.2;
}
.theme-btn .t-example {
  font-size: 11px;
  font-weight: 600;
  color: var(--muted);
}
.theme-btn.active .t-name { color: var(--blue); }
.theme-btn.active .t-example { color: var(--blue); opacity: 0.75; }

/* ─── THEME RULE BOX ──────────────────────────────────── */
.rule-box {
  background: var(--blue-lt);
  border: 2px solid var(--blue-mid);
  border-radius: var(--r);
  padding: 14px 16px;
  margin-bottom: 24px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  animation: fadeSlide 0.25s ease;
}
@keyframes fadeSlide {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.rule-icon { font-size: 24px; flex-shrink: 0; margin-top: 1px; }
.rule-text { flex: 1; }
.rule-title {
  font-size: 14px;
  font-weight: 800;
  color: var(--blue);
  margin-bottom: 4px;
}
.rule-body {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink2);
  line-height: 1.6;
}
.rule-body strong { color: var(--blue); }
.rule-examples {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 8px;
}
.rule-pill {
  background: var(--surface);
  border: 1.5px solid var(--blue-mid);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 13px;
  font-weight: 700;
  color: var(--blue);
}
.rule-pill mark {
  background: none;
  color: var(--red);
  font-weight: 900;
}

/* ─── DIKTAT CARD ─────────────────────────────────────── */
.diktat-card {
  background: var(--surface);
  border: 2px solid var(--border);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  margin-bottom: 16px;
}

/* sentence counter strip */
.sentence-strip {
  background: var(--bg);
  border-bottom: 2px solid var(--border);
  padding: 10px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.sentence-dots {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}
.s-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid var(--border-md);
  background: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 800;
  color: var(--muted);
  cursor: pointer;
  transition: all 0.18s;
  flex-shrink: 0;
}
.s-dot:hover { border-color: var(--blue); color: var(--blue); }
.s-dot.current {
  background: var(--blue);
  border-color: var(--blue);
  color: #fff;
  transform: scale(1.1);
}
.s-dot.done-correct { background: var(--green); border-color: var(--green); color: #fff; }
.s-dot.done-wrong   { background: var(--red);   border-color: var(--red);   color: #fff; }
.s-dot.done-skip    { background: var(--muted);  border-color: var(--muted);  color: #fff; }

.sentence-progress {
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  white-space: nowrap;
}

/* ─── PLAY ZONE ───────────────────────────────────────── */
.play-zone {
  padding: 24px 20px 16px;
  text-align: center;
  border-bottom: 2px solid var(--border);
}

.play-instruction {
  font-size: 13px;
  font-weight: 700;
  color: var(--muted);
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Big play button */
.play-btn {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  border: 3px solid var(--blue);
  background: var(--blue);
  color: #fff;
  font-size: 32px;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  box-shadow: 0 4px 16px rgba(59,108,247,0.35);
  position: relative;
  margin-bottom: 12px;
}
.play-btn:hover {
  transform: scale(1.06);
  box-shadow: 0 6px 24px rgba(59,108,247,0.45);
}
.play-btn:active { transform: scale(0.97); }
.play-btn.playing {
  background: var(--amber);
  border-color: var(--amber);
  box-shadow: 0 4px 16px rgba(192,122,0,0.35);
  animation: pulse-ring 1.2s ease-out infinite;
}
@keyframes pulse-ring {
  0%   { box-shadow: 0 0 0 0 rgba(192,122,0,0.4), 0 4px 16px rgba(192,122,0,0.35); }
  70%  { box-shadow: 0 0 0 16px rgba(192,122,0,0), 0 4px 16px rgba(192,122,0,0.35); }
  100% { box-shadow: 0 0 0 0 rgba(192,122,0,0), 0 4px 16px rgba(192,122,0,0.35); }
}

.play-controls {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
}
.ctrl-btn {
  padding: 7px 14px;
  border: 2px solid var(--border-md);
  border-radius: 20px;
  background: var(--surface);
  color: var(--ink2);
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.18s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.ctrl-btn:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-lt); }
.ctrl-btn.active { background: var(--blue); border-color: var(--blue); color: #fff; }

/* Speed control */
.speed-row {
  display: flex;
  gap: 6px;
  justify-content: center;
  margin-top: 10px;
}
.speed-btn {
  padding: 5px 12px;
  border: 1.5px solid var(--border-md);
  border-radius: 20px;
  background: var(--surface);
  color: var(--muted);
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
}
.speed-btn:hover { border-color: var(--blue); color: var(--blue); }
.speed-btn.active { background: var(--blue-lt); border-color: var(--blue); color: var(--blue); }

/* ─── WRITE ZONE ──────────────────────────────────────── */
.write-zone { padding: 20px; }

.write-label {
  font-size: 13px;
  font-weight: 700;
  color: var(--muted);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.write-label-num {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--blue);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.diktat-input {
  width: 100%;
  padding: 14px 16px;
  border: 2.5px solid var(--border-md);
  border-radius: var(--r);
  font-family: 'Nunito', sans-serif;
  font-size: clamp(17px, 3.5vw, 20px);
  font-weight: 700;
  color: var(--ink);
  background: var(--surface);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
  margin-bottom: 12px;
  letter-spacing: 0.01em;
}
.diktat-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(59,108,247,0.12);
}
.diktat-input.state-correct {
  border-color: var(--green);
  background: var(--green-lt);
  box-shadow: 0 0 0 3px rgba(21,160,86,0.12);
}
.diktat-input.state-wrong {
  border-color: var(--red);
  background: var(--red-lt);
  box-shadow: 0 0 0 3px rgba(212,48,48,0.12);
}

.btn-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.btn-check {
  flex: 1;
  min-width: 140px;
  padding: 13px 20px;
  background: var(--blue);
  color: #fff;
  border: none;
  border-radius: var(--r);
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 3px 10px rgba(59,108,247,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  min-height: 52px;
}
.btn-check:hover { background: #2855d6; transform: translateY(-1px); box-shadow: 0 5px 16px rgba(59,108,247,0.35); }
.btn-check:active { transform: translateY(1px); }
.btn-check:disabled { background: var(--border-md); color: var(--muted); cursor: default; box-shadow: none; transform: none; }

.btn-skip {
  padding: 13px 16px;
  background: transparent;
  color: var(--muted);
  border: 2px solid var(--border-md);
  border-radius: var(--r);
  font-family: 'Nunito', sans-serif;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.18s;
  min-height: 52px;
}
.btn-skip:hover { border-color: var(--muted); color: var(--ink2); }

/* ─── FEEDBACK ────────────────────────────────────────── */
.feedback-box {
  border-radius: var(--r);
  padding: 14px 16px;
  margin-top: 12px;
  display: none;
  font-size: 15px;
  font-weight: 700;
  line-height: 1.5;
  animation: fadeSlide 0.2s ease;
}
.feedback-box.show { display: block; }
.feedback-box.correct {
  background: var(--green-lt);
  border: 2px solid var(--green-mid);
  color: var(--green);
}
.feedback-box.wrong {
  background: var(--red-lt);
  border: 2px solid var(--red-mid);
  color: var(--red);
}
.feedback-box .fb-correct-text {
  font-size: 19px;
  font-weight: 900;
  margin-top: 4px;
  color: var(--ink);
}
.feedback-box .fb-highlight mark {
  background: var(--amber-lt);
  color: var(--amber);
  border-radius: 3px;
  padding: 0 3px;
  font-weight: 900;
}

/* ─── NEXT BUTTON ─────────────────────────────────────── */
.btn-next {
  width: 100%;
  padding: 14px;
  background: var(--green);
  color: #fff;
  border: none;
  border-radius: var(--r);
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  margin-top: 12px;
  display: none;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 0 3px 10px rgba(21,160,86,0.3);
  transition: all 0.2s;
  min-height: 52px;
}
.btn-next.show { display: flex; }
.btn-next:hover { background: #108f48; transform: translateY(-1px); }

/* ─── RESULTS PANEL ───────────────────────────────────── */
.results-panel {
  background: var(--surface);
  border: 2px solid var(--border);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-md);
  padding: 24px;
  display: none;
  animation: fadeSlide 0.3s ease;
}
.results-panel.show { display: block; }
.results-title {
  font-size: 22px;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.results-sub {
  font-size: 14px;
  color: var(--muted);
  font-weight: 600;
  margin-bottom: 20px;
}
.score-bar-wrap {
  background: var(--border);
  border-radius: 10px;
  height: 14px;
  margin-bottom: 16px;
  overflow: hidden;
}
.score-bar {
  height: 100%;
  border-radius: 10px;
  transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
  background: linear-gradient(90deg, var(--green), #3de88a);
}
.results-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.result-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: var(--r-sm);
  font-size: 14px;
  font-weight: 600;
}
.result-row.r-correct { background: var(--green-lt); border: 1.5px solid var(--green-mid); }
.result-row.r-wrong   { background: var(--red-lt);   border: 1.5px solid var(--red-mid); }
.result-row.r-skip    { background: var(--bg);        border: 1.5px solid var(--border-md); color: var(--muted); }
.result-icon { font-size: 18px; flex-shrink: 0; }
.result-written { flex: 1; color: var(--ink); }
.result-correct { color: var(--green); font-weight: 800; }
.result-wrong-text { color: var(--red); text-decoration: line-through; opacity: 0.7; }
.btn-restart {
  width: 100%;
  padding: 14px;
  background: var(--blue);
  color: #fff;
  border: none;
  border-radius: var(--r);
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 3px 10px rgba(59,108,247,0.3);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 52px;
}
.btn-restart:hover { background: #2855d6; transform: translateY(-1px); }

/* ─── CONFETTI ────────────────────────────────────────── */
.confetti-wrap {
  position: fixed; inset: 0;
  pointer-events: none; z-index: 9999;
}
.c-dot {
  position: absolute;
  border-radius: 2px;
  animation: cFall linear forwards;
}
@keyframes cFall {
  from { opacity: 1; transform: translateY(-10px) rotate(0deg); }
  to   { opacity: 0; transform: translateY(105vh) rotate(540deg); }
}

/* ─── HELPER TOAST ────────────────────────────────────── */
.toast {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: var(--ink);
  color: #fff;
  padding: 10px 20px;
  border-radius: 30px;
  font-size: 14px;
  font-weight: 700;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s;
  z-index: 200;
  white-space: nowrap;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ─── HINT BOX ────────────────────────────────────────── */
.hint-box {
  background: var(--amber-lt);
  border: 2px solid var(--amber-mid);
  border-radius: var(--r-sm);
  padding: 10px 14px;
  font-size: 13px;
  font-weight: 700;
  color: var(--amber);
  margin-top: 10px;
  display: none;
  align-items: center;
  gap: 8px;
  line-height: 1.5;
  animation: fadeSlide 0.2s ease;
}
.hint-box.show { display: flex; }

/* ─── ACCESSIBLE FOCUS ────────────────────────────────── */
button:focus-visible, input:focus-visible {
  outline: 3px solid var(--blue);
  outline-offset: 3px;
}

/* ─── RESPONSIVE ──────────────────────────────────────── */
@media (max-width: 480px) {
  .play-btn { width: 76px; height: 76px; font-size: 28px; }
  .theme-grid { grid-template-columns: repeat(auto-fill, minmax(110px,1fr)); }
  .diktat-input { font-size: 17px; }
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation: none !important; transition: none !important; }
}
</style>
</head>
<body>

<div class="confetti-wrap" id="confettiWrap"></div>
<div class="toast" id="toast"></div>

<!-- ── HEADER ──────────────────────────────────────────── -->
<header class="site-header">
  <span class="header-icon">🎧</span>
  <div class="header-titles">
    <div class="header-title">Diktat-Trainer</div>
    <div class="header-sub">Hören · Schreiben · Überprüfen</div>
  </div>
  <span class="header-badge">📚 Klasse 3 Bayern</span>
</header>

<div class="wrap">

  <!-- ── THEME PICKER ─────────────────────────────────── -->
  <div class="section-label">Wähle ein Thema:</div>
  <div class="theme-grid" id="themeGrid"></div>

  <!-- ── RULE BOX ─────────────────────────────────────── -->
  <div class="rule-box" id="ruleBox" style="display:none"></div>

  <!-- ── DIKTAT CARD ──────────────────────────────────── -->
  <div class="diktat-card" id="diktatCard" style="display:none">

    <!-- Sentence dot nav -->
    <div class="sentence-strip">
      <div class="sentence-dots" id="sentenceDots"></div>
      <div class="sentence-progress" id="sentenceProgress">Satz 1 von 6</div>
    </div>

    <!-- Audio play zone -->
    <div class="play-zone">
      <div class="play-instruction">Drücke ▶ um den Satz zu hören</div>
      <button class="play-btn" id="playBtn" onclick="playCurrent()" aria-label="Satz vorlesen">
        ▶
      </button>
      <div class="play-controls">
        <button class="ctrl-btn" id="repeatBtn" onclick="playCurrent()" title="Nochmal hören">
          🔁 Nochmal
        </button>
        <button class="ctrl-btn" id="wordBtn" onclick="playWord()" title="Einzelne Wörter hören">
          🔤 Wort für Wort
        </button>
      </div>
      <div class="speed-row">
        <span style="font-size:11px;font-weight:700;color:var(--muted);margin-right:4px;line-height:2.2">Tempo:</span>
        <button class="speed-btn" onclick="setSpeed(0.65)" data-speed="0.65">🐢 Langsam</button>
        <button class="speed-btn active" onclick="setSpeed(0.85)" data-speed="0.85">🚶 Normal</button>
        <button class="speed-btn" onclick="setSpeed(1.0)" data-speed="1.0">🏃 Schnell</button>
      </div>
      <div id="api-key-bar" style="margin-top:10px;display:flex;gap:6px;justify-content:center;align-items:center;flex-wrap:wrap">
        <span id="api-status" style="font-size:11px;font-weight:700;color:var(--muted)"></span>
        <button class="speed-btn" onclick="changeApiKey()" style="font-size:11px">🔑 API-Schlüssel</button>
      </div>
    </div>

    <!-- Write zone -->
    <div class="write-zone">
      <div class="write-label">
        <span class="write-label-num">2</span>
        Schreibe den Satz hier:
      </div>

      <input
        id="diktatInput"
        class="diktat-input"
