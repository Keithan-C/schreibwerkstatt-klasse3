// ── STATE ─────────────────────────────────────────────────
let currentTheme    = null;
let currentSentIdx  = 0;
let currentSpeed    = 0.85;
let wordMode        = false;
let wordIdx         = 0;
let results         = []; // {sentence, written, correct, skipped}
let checked         = false;
let wordPlayTimeout = null;

// ── INIT ──────────────────────────────────────────────────
function changeApiKey() {
  localStorage.removeItem('el_api_key');
  audioCache = {};
  const key = promptForKey();
  if (key) updateApiStatus();
}

function updateApiStatus() {
  const bar = document.getElementById('api-status');
  if (!bar) return;
  const key = getApiKey();
  if (key) {
    bar.textContent = '✅ ElevenLabs aktiv';
    bar.style.color = 'var(--green)';
  } else {
    bar.textContent = '⚠️ Kein Schlüssel — Browser-Stimme wird verwendet';
    bar.style.color = 'var(--amber)';
  }
}

function init() {
  buildThemeGrid();
  updateApiStatus();
}

function buildThemeGrid() {
  const grid = document.getElementById('themeGrid');
  grid.innerHTML = THEMES.map(t => `
    <button class="theme-btn" id="tb-${t.id}" onclick="selectTheme('${t.id}')" aria-label="${t.name}">
      <span class="t-emoji">${t.emoji}</span>
      <span class="t-name">${t.name}</span>
      <span class="t-example">${t.example}</span>
    </button>
  `).join('');
}

function selectTheme(id) {
  currentTheme = THEMES.find(t => t.id === id);
  if (!currentTheme) return;

  // Update button states
  document.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
  const btn = document.getElementById('tb-' + id);
  if (btn) btn.classList.add('active');

  // Show rule box
  const ruleBox = document.getElementById('ruleBox');
  ruleBox.style.display = 'flex';
  ruleBox.innerHTML = `
    <span class="rule-icon">${currentTheme.emoji}</span>
    <div class="rule-text">
      <div class="rule-title">${currentTheme.name} — Die Regel</div>
      <div class="rule-body">${currentTheme.rule}<br><span style="font-weight:600;opacity:.85">${currentTheme.ruleDetail}</span></div>
      <div class="rule-examples">
        ${currentTheme.examples.map(e => `<span class="rule-pill">${e}</span>`).join('')}
      </div>
    </div>
  `;
  ruleBox.style.animation = 'none';
  void ruleBox.offsetWidth;
  ruleBox.style.animation = '';

  // Start diktat
  startDiktat();
}

function startDiktat() {
  currentSentIdx = 0;
  results = currentTheme.sentences.map(() => null);
  checked = false;

  document.getElementById('resultsPanel').classList.remove('show');
  document.getElementById('diktatCard').style.display = 'block';

  buildDots();
  loadSentence(0);
}

// ── SENTENCE NAVIGATION ───────────────────────────────────
function buildDots() {
  const wrap = document.getElementById('sentenceDots');
  wrap.innerHTML = currentTheme.sentences.map((_, i) =>
    `<div class="s-dot" id="dot-${i}" onclick="jumpTo(${i})">${i+1}</div>`
  ).join('');
  updateDots();
}

function updateDots() {
  currentTheme.sentences.forEach((_, i) => {
    const dot = document.getElementById('dot-' + i);
    if (!dot) return;
    dot.className = 's-dot';
    if (i === currentSentIdx) { dot.classList.add('current'); return; }
    const r = results[i];
    if (r === null) return; // not yet attempted
    if (r === 'skip')    { dot.classList.add('done-skip'); return; }
    dot.classList.add(r.correct ? 'done-correct' : 'done-wrong');
  });
  document.getElementById('sentenceProgress').textContent =
    `Satz ${currentSentIdx + 1} von ${currentTheme.sentences.length}`;
}

function jumpTo(i) {
  // Only allow jumping to done sentences or the current one
  if (i <= currentSentIdx || results[i] !== null) {
    currentSentIdx = i;
    loadSentence(i);
  } else {
    showToast('Schreibe zuerst die vorherigen Sätze!');
  }
}

function loadSentence(i) {
  window.speechSynthesis.cancel();
  wordMode = false; wordIdx = 0;
  checked = false;

  const input = document.getElementById('diktatInput');
  input.value = '';
  input.className = 'diktat-input';
  input.disabled = false;
  input.placeholder = 'Schreib den Satz ab …';

  document.getElementById('feedbackBox').className = 'feedback-box';
  document.getElementById('nextBtn').className = 'btn-next';
  document.getElementById('hintBox').className = 'hint-box';
  document.getElementById('checkBtn').disabled = false;

  updateDots();

  // Auto-play after a short pause (calm, predictable behaviour)
  setTimeout(() => { playCurrent(); }, 400);

  input.focus();
}

// ── AUDIO ─────────────────────────────────────────────────
function playCurrent() {
  if (!currentTheme) return;
  stopAudio();
  clearTimeout(wordPlayTimeout);
  wordMode = false; wordIdx = 0;
  const s = currentTheme.sentences[currentSentIdx];
  speak(s.text, currentSpeed);
}

function playWord() {
  if (!currentTheme) return;
  stopAudio();
  clearTimeout(wordPlayTimeout);
  const s  = currentTheme.sentences[currentSentIdx];
  const words = s.text.split(/\s+/);
  wordIdx = 0;
  wordMode = true;
  // Play words sequentially — each word waits for EL response so we chain via onended
  playNextWordEl(words);
}

function playNextWordEl(words) {
  if (wordIdx >= words.length) { wordMode = false; return; }
  const w = words[wordIdx].replace(/[.,!?]/g, '');
  wordIdx++;
  // After this word finishes, schedule the next one
  const prevOnEnded = null;
  const onThisWordDone = () => {
    wordPlayTimeout = setTimeout(() => { playNextWordEl(words); }, 400);
  };
  // Patch the audio onended for word mode
  speak(w, currentSpeed * 0.88);
  // Override the onended set inside speak() to chain words
  wordPlayTimeout = setTimeout(() => {
    if (currentAudio) {
      const orig = currentAudio.onended;
      currentAudio.onended = () => { if(orig) orig(); onThisWordDone(); };
    } else {
      // Fallback: just use fixed timing
      onThisWordDone();
    }
  }, 80);
}

function setSpeed(rate) {
  currentSpeed = rate;
  document.querySelectorAll('.speed-btn').forEach(b => {
    b.classList.toggle('active', parseFloat(b.dataset.speed) === rate);
  });
}

// ── ANSWER CHECKING ───────────────────────────────────────
function onKey(e) {
  if (e.key === 'Enter') { e.preventDefault(); checkAnswer(); }
}

function onInput() {
  // Remove any previous state while typing
  const input = document.getElementById('diktatInput');
  input.className = 'diktat-input';
  document.getElementById('hintBox').className = 'hint-box';
}

function normalise(str) {
  return str.trim().toLowerCase()
    .replace(/[.,!?;:]/g, '')      // strip punctuation
    .replace(/\s+/g, ' ');         // normalise spaces
}

function checkAnswer() {
  if (checked) return;
  const input = document.getElementById('diktatInput');
  const written = input.value.trim();
  if (!written) { showToast('Schreibe zuerst etwas!'); return; }

  const sentence = currentTheme.sentences[currentSentIdx];
  const correct = normalise(written) === normalise(sentence.text);
  checked = true;

  // Store result
  results[currentSentIdx] = { sentence: sentence.text, written, correct };
  updateDots();

  const fb = document.getElementById('feedbackBox');
  input.disabled = true;

  if (correct) {
    input.className = 'diktat-input state-correct';
    fb.className = 'feedback-box correct show';
    fb.innerHTML = `<div>✅ Richtig! Super gemacht!</div>`;
    launchConfetti();
  } else {
    input.className = 'diktat-input state-wrong';
    // Diff-highlight the correct sentence
    const highlighted = diffHighlight(sentence.text, written);
    fb.className = 'feedback-box wrong show';
    fb.innerHTML = `
      <div>❌ Noch nicht ganz richtig.</div>
      <div class="fb-correct-text">${highlighted}</div>
      <div style="font-size:12px;font-weight:600;margin-top:6px;opacity:.8">
        💡 ${sentence.hint}
      </div>
    `;
  }

  // Show hint for wrong answers
  if (!correct) {
    const hintBox = document.getElementById('hintBox');
    document.getElementById('hintText').textContent = sentence.hint;
    hintBox.className = 'hint-box show';
  }

  // Show next button
  document.getElementById('checkBtn').disabled = true;
  const isLast = currentSentIdx === currentTheme.sentences.length - 1;
  const nextBtn = document.getElementById('nextBtn');
  nextBtn.className = 'btn-next show';
  nextBtn.textContent = isLast ? '📊 Ergebnis anzeigen →' : 'Weiter →';
  nextBtn.innerHTML = isLast
    ? '<span>📊 Ergebnis anzeigen</span>'
    : '<span>Weiter →</span>';
}

// Simple word-level diff — mark wrong words in the correct sentence
function diffHighlight(correct, written) {
  const cWords = correct.replace(/[.,!?]/g, '').split(/\s+/);
  const wWords = written.replace(/[.,!?]/g, '').toLowerCase().split(/\s+/);
  return cWords.map((cw, i) => {
    const ww = (wWords[i] || '').toLowerCase();
    if (ww === cw.toLowerCase()) return cw;
    return `<mark>${cw}</mark>`;
  }).join(' ') + (correct.match(/[.!?]$/) ? correct.slice(-1) : '');
}

function skipSentence() {
  if (checked) return;
  results[currentSentIdx] = 'skip';
  checked = true;
  updateDots();
  const isLast = currentSentIdx === currentTheme.sentences.length - 1;
  const nextBtn = document.getElementById('nextBtn');
  nextBtn.className = 'btn-next show';
  nextBtn.innerHTML = isLast
    ? '<span>📊 Ergebnis anzeigen</span>'
    : '<span>Weiter →</span>';
  document.getElementById('checkBtn').disabled = true;
}

function nextSentence() {
  const isLast = currentSentIdx === currentTheme.sentences.length - 1;
  if (isLast) { showResults(); return; }
  currentSentIdx++;
  loadSentence(currentSentIdx);
}

// ── RESULTS ───────────────────────────────────────────────
function showResults() {
  window.speechSynthesis.cancel();
  document.getElementById('diktatCard').style.display = 'none';

  const panel = document.getElementById('resultsPanel');
  const total   = results.length;
  const correct = results.filter(r => r && r !== 'skip' && r.correct).length;
  const wrong   = results.filter(r => r && r !== 'skip' && !r.correct).length;
  const skipped = results.filter(r => r === 'skip').length;
  const pct = Math.round(correct / total * 100);

  const emoji = pct === 100 ? '🏆' : pct >= 70 ? '🌟' : pct >= 50 ? '😊' : '💪';
  const msg   = pct === 100
    ? 'Perfekt! Alle Sätze richtig!'
    : pct >= 70 ? 'Sehr gut gemacht!'
    : pct >= 50 ? 'Gut versucht — weiter üben!'
    : 'Nicht aufgeben — du schaffst das!';

  const rowsHTML = results.map((r, i) => {
    const sText = currentTheme.sentences[i].text;
    if (r === 'skip' || r === null) {
      return `<div class="result-row r-skip">
        <span class="result-icon">⏭</span>
        <span class="result-written">${sText}</span>
        <span style="font-size:12px">übersprungen</span>
      </div>`;
    }
    if (r.correct) {
      return `<div class="result-row r-correct">
        <span class="result-icon">✅</span>
        <span class="result-written">${r.written}</span>
      </div>`;
    }
    return `<div class="result-row r-wrong">
      <span class="result-icon">❌</span>
      <div style="flex:1">
        <div class="result-wrong-text">${r.written}</div>
        <div class="result-correct">→ ${sText}</div>
      </div>
    </div>`;
  }).join('');

  panel.innerHTML = `
    <div class="results-title">${emoji} Dein Ergebnis</div>
    <div class="results-sub">${currentTheme.name} · ${correct} von ${total} richtig</div>
    <div class="score-bar-wrap">
      <div class="score-bar" style="width:0%" id="scoreBar"></div>
    </div>
    <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap">
      <span style="background:var(--green-lt);border:1.5px solid var(--green-mid);color:var(--green);border-radius:20px;padding:4px 14px;font-size:13px;font-weight:800">✅ ${correct} richtig</span>
      ${wrong  ? `<span style="background:var(--red-lt);border:1.5px solid var(--red-mid);color:var(--red);border-radius:20px;padding:4px 14px;font-size:13px;font-weight:800">❌ ${wrong} falsch</span>` : ''}
      ${skipped? `<span style="background:var(--bg);border:1.5px solid var(--border-md);color:var(--muted);border-radius:20px;padding:4px 14px;font-size:13px;font-weight:800">⏭ ${skipped} übersprungen</span>` : ''}
    </div>
    <div style="font-size:16px;font-weight:800;color:var(--ink);margin-bottom:16px">${msg}</div>
    <div class="results-list">${rowsHTML}</div>
    <button class="btn-restart" onclick="restartTheme()">
      🔄 Nochmal üben
    </button>
    <button class="btn-restart" onclick="pickNewTheme()" style="background:var(--purple);box-shadow:0 3px 10px rgba(107,63,200,0.3);margin-top:8px">
      🎯 Anderes Thema wählen
    </button>
  `;

  panel.classList.add('show');
  panel.scrollIntoView({ behavior: 'smooth', block: 'start' });

  // Animate score bar
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const bar = document.getElementById('scoreBar');
      if (bar) bar.style.width = pct + '%';
    });
  });

  if (pct === 100) launchConfetti();
}

function restartTheme() {
  document.getElementById('resultsPanel').classList.remove('show');
  startDiktat();
  document.getElementById('diktatCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function pickNewTheme() {
  document.getElementById('resultsPanel').classList.remove('show');
  document.getElementById('diktatCard').style.display = 'none';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── CONFETTI ──────────────────────────────────────────────
function launchConfetti() {
  const wrap = document.getElementById('confettiWrap');
  const colors = ['#3B6CF7','#15A056','#F5C842','#D43030','#6B3FC8','#06b6d4','#f97316'];
  for (let i = 0; i < 60; i++) {
    const el = document.createElement('div');
    el.className = 'c-dot';
    const size = 6 + Math.random() * 8;
    el.style.cssText = [
      `left:${Math.random()*100}vw`,
      `top:-12px`,
      `width:${size}px`,
      `height:${size}px`,
      `background:${colors[Math.floor(Math.random()*colors.length)]}`,
      `border-radius:${Math.random()>.5?'50%':'3px'}`,
      `animation-duration:${2+Math.random()*2.5}s`,
      `animation-delay:${Math.random()*.8}s`,
    ].join(';');
    wrap.appendChild(el);
    setTimeout(() => el.remove(), 4000);
  }
}

// ── TOAST ─────────────────────────────────────────────────
let toastTimer = null;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

// ── BOOT ──────────────────────────────────────────────────
init();
</script>
</body>
</html>
