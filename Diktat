<script>
// ── ELEVENLABS TTS — human German voice ──────────────────
// Voice options (all good for German children's educational content):
// EXAVITQu4vr4xnSDxMaL  = "Bella"  — warm, clear female
// jsCqWAovK2LkecY7zXl4  = "Freya"  — natural female, good German
// XrExE9yKIg1WjnnlVkGX  = "Lily"   — warm, friendly female
// pqHfZKP75CvOlQylNhV4  = "Emily"  — calm, clear
// Default: use "Sarah" (multilingual, very clear German)
const EL_VOICE_ID    = 'EXAVITQu4vr4xnSDxMaL'; // Bella — warm female, excellent German
const EL_MODEL_ID    = 'eleven_multilingual_v2'; // Best quality multilingual model
const EL_API_URL     = 'https://api.elevenlabs.io/v1/text-to-speech/';

let elApiKey = localStorage.getItem('el_api_key') || '';
let audioCache = {};   // text → blob URL — avoid re-fetching same sentence
let currentAudio = null;

// ── API key setup ──
function getApiKey() { return localStorage.getItem('el_api_key') || ''; }

function promptForKey() {
  const key = prompt(
    '🔑 ElevenLabs API-Schlüssel eingeben:\n\n' +
    '1. Gehe zu elevenlabs.io und erstelle einen kostenlosen Account\n' +
    '2. Kopiere deinen API-Schlüssel aus "My Account"\n' +
    '3. Füge ihn hier ein — er wird nur auf diesem Gerät gespeichert'
  );
  if (key && key.trim().startsWith('sk_')) {
    localStorage.setItem('el_api_key', key.trim());
    showToast('✅ API-Schlüssel gespeichert!');
    return key.trim();
  } else if (key) {
    showToast('❌ Ungültiger Schlüssel — muss mit sk_ beginnen');
  }
  return null;
}

// ── Core TTS function ──
async function speak(text, rate) {
  let apiKey = getApiKey();

  // If no key, ask once then fall back to browser TTS
  if (!apiKey) {
    apiKey = promptForKey();
    if (!apiKey) {
      speakFallback(text, rate);
      return;
    }
  }

  // Check cache first
  const cacheKey = text + '|' + rate;
  if (audioCache[cacheKey]) {
    playAudioUrl(audioCache[cacheKey]);
    return;
  }

  // Show loading state on play button
  setPlayBtnState('loading');

  // ElevenLabs speed: 0.7–1.2 maps to our 0.65–1.0 range
  const elSpeed = Math.max(0.7, Math.min(1.2, (rate || currentSpeed) / 0.85));

  try {
    const resp = await fetch(EL_API_URL + EL_VOICE_ID + '?output_format=mp3_44100_128', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'xi-api-key': apiKey,
      },
      body: JSON.stringify({
        text: text,
        model_id: EL_MODEL_ID,
        voice_settings: {
          stability: 0.55,          // natural variation, not monotone
          similarity_boost: 0.80,   // stay true to the voice
          style: 0.25,              // slight expressiveness
          use_speaker_boost: true,
          speed: elSpeed,
        },
        language_code: 'de',
      })
    });

    if (resp.status === 401) {
      localStorage.removeItem('el_api_key');
      showToast('❌ API-Schlüssel ungültig — bitte neu eingeben');
      setPlayBtnState('ready');
      speakFallback(text, rate);
      return;
    }
    if (resp.status === 429) {
      showToast('⏳ Zu viele Anfragen — kurz warten…');
      setPlayBtnState('ready');
      speakFallback(text, rate);
      return;
    }
    if (!resp.ok) throw new Error('EL API ' + resp.status);

    const blob    = await resp.blob();
    const blobUrl = URL.createObjectURL(blob);
    audioCache[cacheKey] = blobUrl;
    playAudioUrl(blobUrl);

  } catch(err) {
    console.warn('ElevenLabs TTS failed:', err.message);
    setPlayBtnState('ready');
    speakFallback(text, rate);
  }
}

function playAudioUrl(url) {
  if (currentAudio) {
    currentAudio.pause();
    currentAudio.src = '';
  }
  const audio = new Audio(url);
  currentAudio = audio;
  audio.onplay  = () => setPlayBtnState('playing');
  audio.onended = () => setPlayBtnState('ready');
  audio.onerror = () => setPlayBtnState('ready');
  audio.play().catch(() => setPlayBtnState('ready'));
}

function setPlayBtnState(state) {
  const btn = document.getElementById('playBtn');
  if (!btn) return;
  btn.classList.remove('playing');
  if (state === 'playing') { btn.textContent = '⏸'; btn.classList.add('playing'); }
  else if (state === 'loading') { btn.textContent = '⏳'; }
  else { btn.textContent = '▶'; }
}

function stopAudio() {
  if (currentAudio) { currentAudio.pause(); currentAudio.src = ''; currentAudio = null; }
  setPlayBtnState('ready');
}

// ── Fallback: browser speechSynthesis ──
let _deVoice = null;
function speakFallback(text, rate) {
  if (!('speechSynthesis' in window)) return;
  stopAudio();
  const voices = window.speechSynthesis.getVoices();
  if (!_deVoice) {
    _deVoice = voices.find(v => v.lang.startsWith('de') && !v.remote)
            || voices.find(v => v.lang.startsWith('de'))
            || null;
  }
  const u = new SpeechSynthesisUtterance(text);
  u.lang  = 'de-DE';
  u.rate  = rate !== undefined ? rate : currentSpeed;
  u.pitch = 1.0;
  if (_deVoice) u.voice = _deVoice;
  u.onstart = () => setPlayBtnState('playing');
  u.onend = u.onerror = () => setPlayBtnState('ready');
  window.speechSynthesis.speak(u);
}

